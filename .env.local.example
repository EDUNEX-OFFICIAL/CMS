# Local development — copy this file to .env.local and adjust values
# copy .env.local.example .env.local   (Windows)

NODE_ENV=development
APP_NAME=CMS Platform
LOG_LEVEL=debug

API_PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
QUEUE_PREFIX=cms
WEB_APP_URL=http://localhost:3000
SESSION_COOKIE_NAME=cms_session
SESSION_TTL_SECONDS=604800

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cms_dev
REDIS_URL=redis://localhost:6379

FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your-service-account@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

JWT_SECRET=super_secret_key_change_in_production

S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=cms-dev
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/cms-dev

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

# Dev only — one-click login buttons on http://localhost:3000/login (JSON array, single line)
NEXT_PUBLIC_DEV_QUICK_LOGINS=[{"label":"Your account","email":"you@example.com","password":"YOUR_FIREBASE_PASSWORD"}]
