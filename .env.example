# CMS Platform — environment template
# Copy to .env.local for local development (never commit .env.local)

NODE_ENV=development
APP_NAME=CMS Platform
LOG_LEVEL=debug

# API
API_PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
QUEUE_PREFIX=cms
WEB_APP_URL=http://localhost:3000
SESSION_COOKIE_NAME=cms_session
SESSION_TTL_SECONDS=604800

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cms_dev

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin (backend)
FIREBASE_PROJECT_ID=content-management-syste-d2094
FIREBASE_CLIENT_EMAIL=your-service-account@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Session signing
JWT_SECRET=change_me_in_local_only

# S3-compatible storage (MinIO local)
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=cms-dev
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/cms-dev

# Frontend (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
