# Production server — copy to .env.production on the deploy host (never commit)

NODE_ENV=production
APP_NAME=CMS Platform
LOG_LEVEL=info

# Gateway URL (used by browsers — include /api path prefix via nginx)
NEXT_PUBLIC_API_URL=https://admin.edunexservices.in/api

# API runtime
API_PORT=4000
CORS_ORIGIN=https://admin.edunexservices.in
QUEUE_PREFIX=cms
WEB_APP_URL=https://admin.edunexservices.in
SESSION_COOKIE_NAME=cms_session
SESSION_TTL_SECONDS=604800

# Database (internal Docker network — password only; host is overridden in compose)
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://postgres:change_me_strong_password@postgres:5432/cms

# Redis (internal)
REDIS_URL=redis://redis:6379

# Firebase Admin (backend)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your-service-account@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Session signing — use a long random secret in production
JWT_SECRET=change_me_long_random_secret

# S3-compatible storage (MinIO in docker-compose.server.yml)
S3_ACCESS_KEY=cms_minio_user
S3_SECRET_KEY=change_me_minio_secret
S3_BUCKET=cms-prod
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_PUBLIC_URL=https://admin.edunexservices.in/media

# Frontend (public — baked into web image at build time)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
